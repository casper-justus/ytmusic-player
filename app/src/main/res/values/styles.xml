<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.NowPlayingBar" parent="">
        <item name="android:background">@color/now_playing_bar</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <style name="Widget.SectionTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontWeight">700</item>
    </style>

    <style name="Widget.TrackTitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.TrackArtist" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="Widget.CardImage" parent="">
        <item name="android:scaleType">centerCrop</item>
        <item name="android:adjustViewBounds">true</item>
    </style>
</resources>
